{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "5.0.1",
  "description": "__MSG_appDescription__",
  "minimum_chrome_version": "102",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "default_locale": "en",
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "translations.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "images/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["options.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "128": "images/icon128.png"
  }
}
